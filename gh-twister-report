# ---------------------------------------------------------------------------
# Terminal / colour helpers
# ---------------------------------------------------------------------------

# Honour NO_COLOR (https://no-color.org/) and non-TTY output
_COLOUR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


class C:
    """ANSI colour codes — empty strings when colour is disabled."""

    if _COLOUR:
        RESET = "\033[0m"
        BOLD = "\033[1m"
        DIM = "\033[2m"
        RED = "\033[31m"
        GREEN = "\033[32m"
        YELLOW = "\033[33m"
        BLUE = "\033[34m"
        CYAN = "\033[36m"
        WHITE = "\033[37m"
        BRED = "\033[91m"
        BGREEN = "\033[92m"
        BYELLOW = "\033[93m"
        BBLUE = "\033[94m"
        BCYAN = "\033[96m"
        BWHITE = "\033[97m"
        BG_RED = "\033[41m"
        BG_GREEN = "\033[42m"
        BG_YELLOW = "\033[43m"
        BG_BLUE = "\033[44m"
    else:
        RESET = BOLD = DIM = ""
        RED = GREEN = YELLOW = BLUE = CYAN = WHITE = ""
        BRED = BGREEN = BYELLOW = BBLUE = BCYAN = BWHITE = ""
        BG_RED = BG_GREEN = BG_YELLOW = BG_BLUE = ""


def _tw() -> int:
    """Return terminal width, defaulting to 100."""
    try:
        return min(shutil.get_terminal_size().columns, 120)
    except Exception:
        return 100


def _bar(value: int, total: int, width: int, colour: str = "") -> str:
    """Render a horizontal bar proportional to value/total."""
    if total == 0:
        filled = 0
    else:
        filled = max(0, min(width, round(value / total * width)))
    bar = "█" * filled + "░" * (width - filled)
    return f"{colour}{bar}{C.RESET}" if colour else bar


# Status → colour mapping
_STATUS_COLOUR = {
    "passed": C.BGREEN,
    "failed": C.BRED,
    "error": C.BYELLOW,
    "skipped": C.CYAN,
    "filtered": C.DIM,
    "blocked": C.YELLOW,
}


def _status_colour(status: str) -> str:
    return _STATUS_COLOUR.get(status.lower(), C.WHITE)


# ---------------------------------------------------------------------------
# Visual summary renderer
# ---------------------------------------------------------------------------


def _hline(w: int, left: str = "├", mid: str = "─", right: str = "┤") -> str:
    return left + mid * (w - 2) + right


def _box_top(w: int) -> str:
    return "┌" + "─" * (w - 2) + "┐"


def _box_bot(w: int) -> str:
    return "└" + "─" * (w - 2) + "┘"


def _box_row(text: str, w: int, colour: str = "") -> str:
    inner = w - 4
    padded = text[:inner].ljust(inner)
    return f"│ {colour}{padded}{C.RESET} │"


def print_visual_summary(
    run_id: str,
    json_files: list[Path],
    merged_path: Path,
    merged_data: dict,
    reports: "TwisterReports",
    long_summary: bool = False,
    show_platforms: bool = False,
) -> None:
    """Render the full visual report to stdout."""
    tw = _tw()
    testsuites = merged_data.get("testsuites", [])
    total = len(testsuites)

    # ── Header ──────────────────────────────────────────────────────────────
    title = f"  TWISTER REPORT  —  run {run_id}  "
    pad = max(0, tw - len(title) - 2)
    print()
    print(f"{C.BOLD}{C.BWHITE}{'━' * tw}{C.RESET}")
    print(f"{C.BOLD}{C.BWHITE}{title}{'━' * pad}{C.RESET}")
    print(f"{C.BOLD}{C.BWHITE}{'━' * tw}{C.RESET}")
    print(
        f"  {C.DIM}Artifacts:{C.RESET} {len(json_files)} subset(s)   "
        f"{C.DIM}Total testsuites:{C.RESET} {C.BOLD}{total:,}{C.RESET}   "
        f"{C.DIM}Merged JSON:{C.RESET} {merged_path}"
    )
    print()

    # ── Status summary ───────────────────────────────────────────────────────
    status_counts: Counter = Counter()
    for ts in testsuites:
        status_counts[ts.get("status", "unknown")] += 1

    col_w = tw
    bar_w = max(20, col_w - 32)

    print(f"{C.BOLD}  STATUS SUMMARY{C.RESET}")
    print("  " + _box_top(col_w - 2))

    order = ["passed", "failed", "error", "skipped", "filtered", "blocked"]
    all_statuses = order + [s for s in status_counts if s not in order]

    for status in all_statuses:
        count = status_counts.get(status, 0)
        if count == 0:
            continue
        pct = count / total * 100 if total else 0
        col = _status_colour(status)
        bar = _bar(count, total, bar_w, col)
        label = status.ljust(10)
        row = f"{col}{C.BOLD}{label}{C.RESET}  {count:6,}  {pct:5.1f}%  {bar}"
        print("  " + _box_row(row, col_w - 2))

    print("  " + _box_bot(col_w - 2))
    print()

    # ── Failure breakdown ────────────────────────────────────────────────────
    if not reports.errors.counters:
        print(f"  {C.BGREEN}{C.BOLD}No failures found.{C.RESET}")
        print()
        return

    failed_total = sum(
        status_counts.get(s, 0) for s in ("failed", "error")
    )

    print(f"{C.BOLD}  FAILURE BREAKDOWN{C.RESET}  "
          f"{C.BRED}{C.BOLD}{failed_total:,}{C.RESET} testsuite(s) with errors/failures")
    print("  " + _box_top(col_w - 2))
    print("  " + _box_row(
        f"{'COUNT':>6}  {'REASON'}", col_w - 2, colour=f"{C.BOLD}{C.DIM}"
    ))
    print("  " + _hline(col_w - 2))

    if long_summary:
        _print_errors_tree(reports.errors, col_w, bar_w, failed_total)
    else:
        _print_top_errors(reports.errors, col_w, bar_w, failed_total)

    print("  " + _box_bot(col_w - 2))
    print()

    # ── Platforms ────────────────────────────────────────────────────────────
    if show_platforms and reports.platforms.counters:
        _print_platforms_table(reports.platforms, col_w, bar_w, failed_total)

    # ── Footer ───────────────────────────────────────────────────────────────
    print(f"{C.DIM}{'─' * tw}{C.RESET}")
    # Outcome indicator
    pass_count = status_counts.get("passed", 0)
    if failed_total == 0:
        verdict = f"{C.BG_GREEN}{C.BOLD}  ALL PASS  {C.RESET}"
    elif pass_count == 0:
        verdict = f"{C.BG_RED}{C.BOLD}  ALL FAIL  {C.RESET}"
    else:
        pct_pass = pass_count / total * 100 if total else 0
        bg = C.BG_GREEN if pct_pass >= 90 else C.BG_YELLOW if pct_pass >= 70 else C.BG_RED
        verdict = f"{bg}{C.BOLD}  {pct_pass:.1f}% passed  {C.RESET}"
    print(f"  {verdict}  {C.DIM}passed={pass_count:,}  failed={failed_total:,}  "
          f"total={total:,}{C.RESET}")
    print()


def _print_top_errors(errors: "Counters", col_w: int, bar_w: int, total: int, n: int = 15):
    for key, value in errors.get_most_common(n=n).items():
        count = value.quantity
        pct = count / total * 100 if total else 0
        bar = _bar(count, total, bar_w // 2, C.BRED)
        label = key[:col_w - 26]
        row = f"{C.BRED}{C.BOLD}{count:6,}{C.RESET}  {label:<{col_w - 26}}  {pct:4.1f}%  {bar}"
        print("  " + _box_row(row, col_w - 2))


def _print_errors_tree(errors: "Counters", col_w: int, bar_w: int, total: int, indent: int = 0):
    for key, value in errors.counters.items():
        count = value.quantity
        pct = count / total * 100 if total else 0
        bar = _bar(count, total, bar_w // 2, C.BRED if indent == 0 else C.YELLOW)
        col = f"{C.BRED}{C.BOLD}" if indent == 0 else f"{C.YELLOW}"
        prefix = "  " * indent
        max_key = col_w - 28 - len(prefix)
        label = key[:max(10, max_key)]
        row = (
            f"{col}{count:6,}{C.RESET}  {prefix}{label:<{max(10, max_key)}}  "
            f"{pct:4.1f}%  {bar}"
        )
        print("  " + _box_row(row, col_w - 2))
        if value.has_subcounters():
            _print_errors_tree(value.subcounters, col_w, bar_w, total, indent + 1)


def _print_platforms_table(platforms: "Counters", col_w: int, bar_w: int, total: int):
    print(f"{C.BOLD}  TOP FAILING PLATFORMS{C.RESET}")
    print("  " + _box_top(col_w - 2))
    print("  " + _box_row(
        f"{'COUNT':>6}  {'PLATFORM'}", col_w - 2, colour=f"{C.BOLD}{C.DIM}"
    ))
    print("  " + _hline(col_w - 2))
    sorted_plats = sorted(
        platforms.counters.items(), key=lambda x: x[1].quantity, reverse=True
    )
    for key, value in sorted_plats[:20]:
        count = value.quantity
        pct = count / total * 100 if total else 0
        bar = _bar(count, total, bar_w // 2, C.BYELLOW)
        label = key[:col_w - 26]
        row = (
            f"{C.BYELLOW}{C.BOLD}{count:6,}{C.RESET}  {label:<{col_w - 26}}  "
            f"{pct:4.1f}%  {bar}"
        )
        print("  " + _box_row(row, col_w - 2))
    print("  " + _box_bot(col_w - 2))
    print()


# ---------------------------------------------------------------------------
# Inline analysis logic (mirrors scripts/ci/twister_report_analyzer.py)
# ---------------------------------------------------------------------------


@dataclass
class TestCollection:
    quantity: int = 0
    tests: list = field(default_factory=list)
    subcounters: "Counters" = field(default_factory=lambda: Counters())

    def append(self, test: str = ""):
        self.quantity += 1
        if test:
            self.tests.append(test)

    def has_subcounters(self):
        return bool(self.subcounters.counters)


@dataclass
class Counters:
    counters: dict = field(default_factory=dict)

    def add_counter(self, key: str, test: str = "") -> None:
        self.counters[key] = self.counters.get(key, TestCollection())
        self.counters[key].append(test)

    def print_counters(self, indent: int = 0):
        for key, value in self.counters.items():
            print(f'{" " * indent}{value.quantity:4}    {key}')
            if value.has_subcounters():
                value.subcounters.print_counters(indent + 4)

    def sort_by_quantity(self):
        self.counters = dict(
            sorted(self.counters.items(), key=lambda item: item[1].quantity, reverse=True)
        )
        for value in self.counters.values():
            if value.has_subcounters():
                value.subcounters.sort_by_quantity()

    def get_next_entry(self, depth: int = 0, max_depth: int = 10):
        for key, value in self.counters.items():
            yield depth, value.quantity, key, ", ".join(value.tests[0:100])
            if value.has_subcounters() and depth < max_depth:
                yield from value.subcounters.get_next_entry(depth + 1, max_depth)

    def _flatten(self):
        for key, value in self.counters.items():
            if value.has_subcounters():
                yield from value.subcounters._flatten()
            else:
                yield key, value

    def get_most_common(self, n: int = 10):
        return dict(
            sorted(self._flatten(), key=lambda item: item[1].quantity, reverse=True)[:n]
        )


class TwisterReports:
    def __init__(self):
        self.status: Counters = Counters()
        self.errors: Counters = Counters()
        self.platforms: Counters = Counters()

    def parse_report(self, json_filename):
        logger.info(f"Process {json_filename}")
        with open(json_filename) as fh:
            json_data = json.load(fh)
        for ts in json_data.get("testsuites", []):
            self.parse_statuses(ts)
        for ts in json_data.get("testsuites", []):
            self.parse_testsuite(ts)

    def parse_statuses(self, testsuite):
        ts_status = testsuite.get("status", "no status in testsuite")
        self.status.add_counter(ts_status)
        for tc in testsuite.get("testcases", []):
            tc_status = tc.get("status")
            self.status.counters[ts_status].subcounters.add_counter(tc_status)

    def parse_testsuite(self, testsuite):
        ts_status = testsuite.get("status") or "no status in testsuite"
        if ts_status not in ("error", "failed"):
            return
        ts_platform = testsuite.get("platform") or "Unknown platform"
        self.platforms.add_counter(ts_platform)
        ts_reason = testsuite.get("reason") or "Unknown reason"
        ts_log = testsuite.get("log")
        test_identifier = f'{testsuite.get("platform")}:{testsuite.get("name")}'
        if ts_reason.startswith("CMake build failure"):
            reason = "CMake build failure"
            self.errors.add_counter(reason)
            error_key = ts_reason.split(reason, 1)[-1].lstrip(" -")
            if not error_key:
                error_key = self._parse_cmake_build_failure(ts_log)
            self.errors.counters[reason].subcounters.add_counter(error_key, test_identifier)
            ts_reason = reason
        elif ts_reason.startswith("Build failure"):
            reason = "Build failure"
            self.errors.add_counter(reason)
            error_key = ts_reason.split(reason, 1)[-1].lstrip(" -")
            if not error_key:
                error_key = self._parse_build_failure(ts_log)
            self.errors.counters[reason].subcounters.add_counter(error_key, test_identifier)
            ts_reason = reason
        else:
            self.errors.add_counter(ts_reason)
        for tc in testsuite.get("testcases", []):
            tc_reason = tc.get("reason")
            tc_log = tc.get("log")
            if tc_reason and tc_log:
                self.errors.counters[ts_reason].subcounters.add_counter(
                    tc_reason, test_identifier
                )
        if not self.errors.counters[ts_reason].has_subcounters():
            self.errors.counters[ts_reason].tests.append(test_identifier)

    def _parse_cmake_build_failure(self, log: str | None) -> str:
        if not log:
            return "No matching CMake error pattern found"
        last_warning = "no warning found"
        lines = log.splitlines()
        for i, line in enumerate(lines):
            if "warning: " in line:
                last_warning = line
            elif "devicetree error: " in line:
                return "devicetree error"
            elif "fatal error: " in line:
                return line[line.index("fatal error: "):].strip()
            elif "error: " in line:
                if "undefined symbol" in last_warning:
                    return last_warning[last_warning.index("undefined symbol"):].strip()
                return last_warning
            elif "CMake Error at" in line:
                for next_line in lines[i + 1:]:
                    if next_line.strip():
                        return line + " " + next_line
                return line
        return "No matching CMake error pattern found"

    def _parse_build_failure(self, log: str | None) -> str:
        if not log:
            return "No matching build error pattern found"
        last_warning = ""
        lines = log.splitlines()
        for i, line in enumerate(lines):
            if "undefined reference" in line:
                return line[line.index("undefined reference"):].strip()
            elif "error: ld returned" in line:
                if last_warning:
                    return last_warning
                elif i > 0 and "overflowed by" in lines[i - 1]:
                    return "ld.bfd: region overflowed"
                elif i > 0 and "ld.bfd: warning: " in lines[i - 1]:
                    return "ld.bfd:" + lines[i - 1].split("ld.bfd:", 1)[-1]
                return line
            elif "error: " in line:
                return line[line.index("error: "):].strip()
            elif ": in function " in line:
                last_warning = line[line.index("in function"):].strip()
        return "No matching build error pattern found"

    def sort_counters(self):
        self.status.sort_by_quantity()
        self.platforms.sort_by_quantity()
        self.errors.sort_by_quantity()


class EnhancedJSONEncoder(json.JSONEncoder):
    def default(self, o):
        if is_dataclass(o):
            return asdict(o)
        return super().default(o)


