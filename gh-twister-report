def gh(*args, check=True, capture=True):
    """Run a gh CLI sub-command and return its stdout as a string."""
    cmd = ["gh"] + list(args)
    logger.debug("Running: %s", " ".join(cmd))
    result = subprocess.run(
        cmd,
        check=check,
        text=True,
        capture_output=capture,
    )
    return result.stdout.strip() if capture else None


def gh_json(*args):
    """Run gh with --json flag and return parsed JSON."""
    raw = gh(*args)
    return json.loads(raw) if raw else []


def resolve_run_id(args) -> str:
    """Determine the workflow run ID from CLI options."""
    if args.run_id:
        return str(args.run_id)

    repo_flag = ["--repo", args.repo] if args.repo else []

    if args.pr:
        logger.info("Looking up latest twister run for PR #%s …", args.pr)
        try:
            pr_info = gh_json(
                "pr", "view", str(args.pr),
                "--json", "headRefOid,headRefName,number",
                *repo_flag,
            )
        except subprocess.CalledProcessError as exc:
            sys.exit(f"ERROR: Could not fetch PR #{args.pr}: {exc}")

        head_sha = pr_info.get("headRefOid", "")
        head_branch = pr_info.get("headRefName", "")

        if not head_sha:
            sys.exit(f"ERROR: Could not determine head SHA for PR #{args.pr}")

        # Search by exact commit SHA — reliable for both same-repo branches and forks.
        logger.info("Searching for twister runs on commit %s …", head_sha[:12])
        try:
            runs = gh_json(
                "run", "list",
                "--workflow", WORKFLOW_FILE,
                "--commit", head_sha,
                "--json", "databaseId,status,conclusion,event,displayTitle",
                "--limit", "10",
                *repo_flag,
            )
        except subprocess.CalledProcessError as exc:
            sys.exit(f"ERROR: gh run list failed: {exc}")

        if runs:
            run_id = str(runs[0]["databaseId"])
            logger.info(
                "Found run %s for PR #%s (commit %s)", run_id, args.pr, head_sha[:12]
            )
            return run_id

        # Fallback: search by branch name with a generous limit in case the commit
        # SHA lookup returned nothing (e.g. older gh versions without --commit support).
        logger.info(
            "No run found by SHA, falling back to branch '%s' …", head_branch
        )
        try:
            runs = gh_json(
                "run", "list",
                "--workflow", WORKFLOW_FILE,
                "--branch", head_branch,
                "--json", "databaseId,headSha,status,conclusion",
                "--limit", "50",
                *repo_flag,
            )
        except subprocess.CalledProcessError as exc:
            sys.exit(f"ERROR: gh run list (branch fallback) failed: {exc}")

        for run in runs:
            if run.get("headSha", "").startswith(head_sha[:12]):
                run_id = str(run["databaseId"])
                logger.info(
                    "Found run %s for PR #%s via branch fallback", run_id, args.pr
                )
                return run_id

        sys.exit(
            f"ERROR: No twister workflow run found for PR #{args.pr}\n"
            f"       head SHA:    {head_sha}\n"
            f"       head branch: {head_branch}\n"
            f"       Tip: pass --run-id <id> to specify the run directly."
        )

    branch = args.branch or "main"
    logger.info("Looking up latest twister run on branch '%s' …", branch)
    try:
        runs = gh_json(
            "run", "list",
            "--workflow", WORKFLOW_FILE,
            "--branch", branch,
            "--json", "databaseId,status,conclusion",
            "--limit", "5",
            *repo_flag,
        )
    except subprocess.CalledProcessError as exc:
        sys.exit(f"ERROR: gh run list failed: {exc}")

    if not runs:
        sys.exit(f"ERROR: No twister workflow runs found on branch '{branch}'")

    run_id = str(runs[0]["databaseId"])
    logger.info("Using latest run %s on branch '%s'", run_id, branch)
    return run_id


